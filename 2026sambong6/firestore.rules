rules_version = '2';
// sambong-world-2026 단일 Firestore — 삼봉 월드(artifacts) + ncgame(loginByName, users) 통합 규칙
// Firebase 콘솔 → Firestore → 규칙에 붙여넣거나: firebase deploy --only firestore

service cloud.firestore {
  match /databases/{database}/documents {
    // --- 삼봉 월드 (sambongWorld.js) ---
    function signedIn() {
      return request.auth != null;
    }

    function studentCreateIsSafe() {
      return signedIn()
        && request.resource.data.xp is number
        && request.resource.data.bong is number
        && request.resource.data.xp >= 0
        && request.resource.data.bong >= -100;
    }

    function studentUpdateIsSafe() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        // XP: 하락(마스터 수정·차감) 허용, 1회 저장 상승은 650 이하(비정상 급등 방지)
        && (!changed.hasAny(['xp']) || (
          request.resource.data.xp is number
          && request.resource.data.xp >= 0
          && (
            request.resource.data.xp <= resource.data.xp
            || request.resource.data.xp <= resource.data.xp + 650
          )
        ))
        // 봉은 정상 구매/점심 차감만 허용하고, 오래 열린 창의 큰 마이너스 덮어쓰기는 차단합니다.
        && (!changed.hasAny(['bong'])
          || request.resource.data.bong >= resource.data.bong
          || (
            request.resource.data.bong >= -100
            && request.resource.data.bong >= resource.data.bong - 600
          ));
    }

    match /artifacts/{appId}/public/data/students/{studentId} {
      allow read: if true;
      allow create: if studentCreateIsSafe();
      allow update: if studentUpdateIsSafe();
      allow delete: if false;
    }

    match /artifacts/{appId}/public/data/{collectionId}/{document=**} {
      allow read: if true;
      // 학생 문서는 위의 전용 안전 규칙만 적용되도록 넓은 공개 쓰기 규칙에서 제외합니다.
      allow write: if request.auth != null && collectionId != 'students';
    }

    match /artifacts/{appId}/public/{collectionId}/{document=**} {
      allow read: if true;
      // /public/data/** 는 위 규칙에서 세분화해 처리합니다.
      allow write: if request.auth != null && collectionId != 'data';
    }

    match /classes/{classId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- ncgame ---
    match /loginByName/{name} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /ncgameHofByPack/{packId}/entries/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.packId == packId;
      allow delete: if false;
    }

    // --- PicBook (picbook 앱) — 회원·구매·연출, 삼봉월드와 동일 Firebase 프로젝트 ---
    match /picbook_accounts/{accountKey} {
      allow read, write: if request.auth != null;
    }

    match /picbook_published_timelines/{bookId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /visual_dictionary/{wordId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /visual_dictionary_stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
