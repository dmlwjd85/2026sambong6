rules_version = '2';
// Firebase 콘솔 → Firestore → 규칙에 붙여넣거나: firebase deploy --only firestore
// 익명 로그인(request.auth != null) 사용자가 artifacts/.../public 하위에 읽기·쓰기 가능해야
// 광장 지급(타 학생 문서)·퀘스트 저장이 동작합니다.
service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
